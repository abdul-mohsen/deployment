# =============================================================================
# install.env — Bootstrap values for install.sh
# =============================================================================
# Copy to install.env and edit. Never commit install.env (it contains secrets).
#   cp install.env.example install.env
#   $EDITOR install.env
#   sudo bash install.sh
#
# Anything NOT set here uses the default shown in comments. CLI flags on
# install.sh override these values.
# =============================================================================

# ---- Domain (required) -------------------------------------------------------
# Tenants will live at <name>.${BASE_DOMAIN}, e.g. dev.dev.example.com
BASE_DOMAIN=dev.example.com

# Email used by Let's Encrypt for cert renewal notices (only when ENABLE_SSL=true)
ACME_EMAIL=you@example.com

# ---- TLS --------------------------------------------------------------------
# TLS is handled by the operator's host nginx, not by this repo.
ENABLE_SSL=false

# ---- Nginx (required) --------------------------------------------------------
# host nginx runs on 80/443; Dokku listens on DOKKU_PORT only.
NGINX_MODE=behind-nginx
DOKKU_PORT=8080

# Dokku hostname (advertised by the container). Default suitable for local/dev:
# e.g. localtest.me. For production set this to your real domain.
DOKKU_HOSTNAME=localtest.me

# ---- MySQL on the host (required) -------------------------------------------
# `host.docker.internal` resolves to the host from inside Docker containers.
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306

# Admin/deployer credentials — used ONLY by the orchestrator on this server
# to provision per-tenant databases and users. NOT used by application
# containers. Best practice: create a dedicated `dokku_admin` user (NOT root)
# scoped to the docker bridge subnet (172.%).
#
# Minimum SQL to create it (run as MySQL root via the local socket):
#
#   CREATE USER 'dokku_admin'@'172.%' IDENTIFIED BY 'STRONG_PASSWORD';
#   -- Tenant DBs (pattern: tenant_<name>) — full lifecycle
#   GRANT CREATE, DROP, ALTER, INDEX, REFERENCES,
#         SELECT, INSERT, UPDATE, DELETE,
#         LOCK TABLES, SHOW VIEW, TRIGGER
#       ON `tenant\_%`.* TO 'dokku_admin'@'172.%' WITH GRANT OPTION;
#   -- Master registry — CRUD on the `tenant` table
#   GRANT SELECT, INSERT, UPDATE, DELETE, CREATE, ALTER, INDEX
#       ON `zatca_master`.* TO 'dokku_admin'@'172.%';
#   -- Global privileges that cannot be schema-scoped:
#   -- CREATE USER lets deployment create tenant DB users.
#   -- SET_USER_ID lets MySQL 8 create triggers while binary logging is enabled,
#   -- without granting SUPER or enabling log_bin_trust_function_creators.
#   GRANT CREATE USER ON *.* TO 'dokku_admin'@'172.%';
#   GRANT SET_USER_ID ON *.* TO 'dokku_admin'@'172.%';
#
# (If you change MYSQL_MASTER_DB below, swap zatca_master in the grant.)
MYSQL_ROOT_USER=dokku_admin
MYSQL_ROOT_PASSWORD=changeme

# Subnet from which tenant DB users are allowed to connect.
# Default 172.% covers Docker's default bridge networks.
MYSQL_TENANT_HOST=172.%

# Master DB stores the tenant registry
MYSQL_MASTER_DB=zatca_master

# ---- Docker Hub (required for auto-deploy) ----------------------------------
# Your username (the auto-deploy will pull <user>/api:dev and <user>/web:dev)
DOCKERHUB_USERNAME=
# Production tag (only used when you run deploy-all.sh manually)
PULL_TAG=latest

# ---- Apps per tenant --------------------------------------------------------
# Space-separated list of app slots each tenant gets. Each entry maps to a
# Dokku app `<tenant>-<slot>` and a Docker Hub repo `<DOCKERHUB_USERNAME>/<image>`.
# The list is open-ended; today the scripts ship support for backend+frontend.
APPS="backend frontend"
APP_IMAGE_backend=api
APP_IMAGE_frontend=web
# To add a third app later (e.g. a worker), append to APPS and add a mapping:
#   APPS="backend frontend worker"
#   APP_IMAGE_worker=worker

# ---- Dev environment --------------------------------------------------------
DEV_TENANT=dev
DEV_TAG=dev

# ---- Webhook secret (auto-generated if left empty) --------------------------
# Used to authenticate POST /deploy from GitHub Actions. Echo `openssl rand -hex 32`
WEBHOOK_SECRET=

# ---- Storage paths ----------------------------------------------------------
STORAGE_ROOT=/opt/tenant-data
BACKUP_DIR=/opt/tenant-backups
