# Backend local-dev environment
# Copy to .env and edit. Never commit .env.

# Database
DB_NAME=app_dev
DB_USER=root
DB_PASSWORD=devpass
DB_PORT_HOST=3307

# API
API_PORT=3000
NODE_ENV=development

# App-specific secrets (uncomment as needed)
# JWT_SECRET=
# ENCRYPTION_KEY=

# Tag used by `docker compose build` for local image
IMAGE_NAME=local/api
