# =============================================================================
# Dokku Multi-Tenant Configuration
# =============================================================================
# Copy to config.env and edit:  cp config.env.example config.env
# =============================================================================

# Your base domain — tenants become <tenant>.BASE_DOMAIN
# DNS: Point *.app.example.com → your server IP
BASE_DOMAIN=app.example.com

# Email for Let's Encrypt SSL certificates
ACME_EMAIL=admin@example.com

# Nginx mode: host nginx wildcards *.BASE_DOMAIN to 127.0.0.1:DOKKU_PORT;
# Dokku's internal nginx routes by Host header. No per-tenant host ports.
NGINX_MODE=behind-nginx

# Port for Dokku's internal nginx (used by behind-nginx-shared mode).
# Your host nginx proxies to this port on 127.0.0.1.
DOKKU_PORT=8080

# Hostname Dokku will advertise (used by the Dokku container). Default for
# local/dev: localtest.me. Set to your base domain in production.
DOKKU_HOSTNAME=localtest.me

# Max upload size for the host-nginx vhost (templates/nginx/host-shared.conf)
NGINX_CLIENT_MAX_BODY_SIZE=50m

# Host path for persistent tenant files
STORAGE_ROOT=/opt/tenant-data

# Backup directory
BACKUP_DIR=/opt/tenant-backups

# =============================================================================
# External MySQL — single instance, one database per tenant
# =============================================================================
# MySQL connection (your existing MySQL server on the host)
# Dokku and all tools run in Docker — use host.docker.internal to reach the host
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=changeme

# Master database — stores tenant registry (created by setup.sh)
MYSQL_MASTER_DB=zatca_master

# =============================================================================
# Message Service (optional — e.g. RabbitMQ, Redis)
# =============================================================================
# If your message service runs on the host, use host.docker.internal
# These env vars are injected into every backend container
#MSG_HOST=host.docker.internal
#MSG_PORT=5672

# =============================================================================
# Docker Hub — public images (used by auto-pull.sh, webhook, and dashboard version picker)
# =============================================================================
# Your Docker Hub username — images are derived as:
#   backend: <DOCKERHUB_USERNAME>/ifritah-api
#   frontend: <DOCKERHUB_USERNAME>/ifritah-web
DOCKERHUB_USERNAME=youruser

# Override image names if different from defaults:
#BACKEND_IMAGE=youruser/ifritah-api
#FRONTEND_IMAGE=youruser/ifritah-web

# Dashboard-compatible release tags. The dashboard deploys:
#   backend:  BACKEND_IMAGE:<selected-version>
#   frontend: FRONTEND_IMAGE:<selected-version>
# Keep frontend/backend compatibility by publishing both images with the same tag.
APP_IMAGE_VERSIONS=dev,latest,stable
APP_IMAGE_VERSION_DEFAULT=dev

# Tag to track for auto-pull (default: latest)
PULL_TAG=latest

# =============================================================================
# Dev environment (single tenant that auto-deploys from the `dev` branch)
# =============================================================================
# A dedicated tenant whose backend tracks <image>:DEV_TAG instead of :PULL_TAG.
# Pushes to the `dev` branch in your backend/frontend repo build :dev images
# and auto-pull.sh deploys them only to this tenant.
#
# Create with:  bash scripts/setup-dev-tenant.sh
DEV_TENANT=dev
DEV_TAG=dev

# Tenant DB schema/migrations are read from the backend image by
# scripts/init-tenant-db.sh. Deployment does not own schema files.
TENANT_SCHEMA_IMAGE_PATH=/app/db/schema/schema.sql
TENANT_MIGRATIONS_IMAGE_DIR=/app/db/migrations

# Pull requested images before using them so mutable tags like :dev do not use
# stale local cache. Values: always, missing, never.
IMAGE_PULL_POLICY=always
TENANT_IMAGE_PULL_POLICY=always

# Optional backend command to run after image deploy (empty = skip). Leave this
# empty unless the backend image actually contains the migration tool/files.
MIGRATE_CMD=

# =============================================================================
# Webhook Deploy (optional — alternative to polling)
# =============================================================================
# Shared secret for webhook authentication
# Generate with:  openssl rand -hex 32
# Set the same value as WEBHOOK_SECRET in your GitHub repo secrets
#WEBHOOK_SECRET=
